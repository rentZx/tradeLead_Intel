# TradeLead Intel V2.0-RC1 environment template

# Streamlit
STREAMLIT_SERVER_ADDRESS=127.0.0.1
STREAMLIT_SERVER_PORT=8501

# SQLite database path used by the app
TRADELEAD_DB_PATH=data/tradelead.sqlite3

# Search API providers. Fill only the provider you plan to use.
SERPAPI_API_KEY=
BING_SEARCH_API_KEY=
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# Optional OpenAI key for future AI-assisted prompts.
OPENAI_API_KEY=

# Landing page inquiry receiver
INQUIRY_SERVER_HOST=127.0.0.1
INQUIRY_SERVER_PORT=8765

# Compliance screening defaults
SANCTIONS_MATCH_THRESHOLD=88
